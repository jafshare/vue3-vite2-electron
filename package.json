{
  "name": "Vue3-Vite2-Electron",
  "version": "0.0.0-alpha.0",
  "main": "dist/main/index.cjs",
  "author": "HunterJiang",
  "scripts": {
    "dev": "node scripts/watch.mjs",
    "prebuild": "vue-tsc --noEmit --p packages/renderer/tsconfig.json && node scripts/build.mjs",
    "build": "electron-builder",
    "init": "git config core.hooksPath .git/hooks/ && npx rimraf .git/hooks && npx simple-git-hooks",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "test:e2e": "npx playwright test",
    "test:e2e:headless": "npx playwright test --headed"
  },
  "engines": {
    "node": ">=14.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.19.2",
    "@rushstack/eslint-patch": "^1.1.1",
    "@types/anyproxy": "^4.1.2",
    "@types/ws": "^8.5.3",
    "@vitejs/plugin-vue": "^2.1.0",
    "@vue/eslint-config-prettier": "^7.0.0",
    "@vue/eslint-config-typescript": "^10.0.0",
    "@vueuse/core": "^8.2.4",
    "anyproxy": "^4.1.3",
    "electron": "18.0.1",
    "electron-builder": "^22.14.5",
    "electron-log": "^4.4.6",
    "element-plus": "^2.1.8",
    "eslint": "^8.12.0",
    "eslint-plugin-vue": "^8.5.0",
    "http-proxy-agent": "^5.0.0",
    "husky": "^7.0.4",
    "lodash": "^4.17.21",
    "nano-staged": "^0.6.0",
    "node-fetch": "2",
    "pinia": "^2.0.13",
    "prettier": "^2.6.2",
    "rimraf": "^3.0.2",
    "sass": "^1.49.11",
    "simple-git-hooks": "^2.7.0",
    "typescript": "^4.6.3",
    "unplugin-auto-import": "^0.6.9",
    "unplugin-vue-components": "^0.18.5",
    "vite": "^2.8.6",
    "vite-plugin-electron-renderer": "^0.3.2",
    "vite-plugin-resolve": "^2.0.1",
    "vite-plugin-windicss": "^1.8.3",
    "vue": "^3.2.31",
    "vue-tsc": "^0.31.1",
    "windicss": "^3.5.1"
  },
  "env": {
    "VITE_DEV_SERVER_HOST": "127.0.0.1",
    "VITE_DEV_SERVER_PORT": 3344
  },
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue"
  ],
  "packageManager": "pnpm",
  "dependencies": {
    "nanoid": "^3.3.2",
    "ws": "^8.5.0"
  }
}
